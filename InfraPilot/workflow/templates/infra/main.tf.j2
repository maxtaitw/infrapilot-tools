{% set normalized_project_name = project_name | lower | replace(" ", "-") | replace("_", "-") %}
terraform {
  required_providers {
    aws = {
      source  = "hashicorp/aws"
      version = "~> 5.0"
    }
  }
}

provider "aws" {
  region = "{{ region }}"
}

resource "aws_vpc" "main" {
  cidr_block = "{{ vpc_cidr }}"

  tags = {
    Name = "{{ normalized_project_name }}-vpc"
  }
}

resource "aws_ecs_cluster" "main" {
  name = "{{ normalized_project_name }}-cluster"
}

resource "aws_ecr_repository" "main" {
  name = "{{ normalized_project_name }}-repo"
}

output "vpc_id" {
  value = aws_vpc.main.id
}

output "ecs_cluster_name" {
  value = aws_ecs_cluster.main.name
}

output "ecr_repository_url" {
  value = aws_ecr_repository.main.repository_url
}
