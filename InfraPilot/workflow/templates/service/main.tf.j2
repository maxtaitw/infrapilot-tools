{% set normalized_service_name = service_name | lower | replace(" ", "-") | replace("_", "-") %}
resource "aws_cloudwatch_log_group" "main" {
  name              = "/ecs/{{ normalized_service_name }}"
  retention_in_days = 7
}

resource "aws_lb_target_group" "main" {
  name        = "{{ normalized_service_name }}-tg"
  port        = {{ port }}
  protocol    = "HTTP"
  target_type = "ip"
  vpc_id      = "{{ vpc_id }}"

  health_check {
    path                = "/"
    healthy_threshold   = 2
    unhealthy_threshold = 3
  }
}

resource "aws_lb_listener_rule" "main" {
  listener_arn = "{{ alb_listener_arn }}"
  priority     = 100

  action {
    type             = "forward"
    target_group_arn = aws_lb_target_group.main.arn
  }

  condition {
    path_pattern {
      values = ["/{{ normalized_service_name }}*"]
    }
  }
}

resource "aws_ecs_task_definition" "main" {
  family                   = "{{ normalized_service_name }}"
  requires_compatibilities = ["FARGATE"]
  network_mode             = "awsvpc"
  execution_role_arn       = "{{ ecs_task_execution_role_arn }}"
  cpu                      = "{{ cpu }}"
  memory                   = "{{ memory }}"

  container_definitions = jsonencode([
    {
      name      = "{{ normalized_service_name }}"
      image     = "{{ ecr_url }}:{{ image_tag }}"
      essential = true

      portMappings = [
        {
          containerPort = {{ port }}
          hostPort      = {{ port }}
          protocol      = "tcp"
        }
      ]

      environment = [
{% for name, value in environment_variables.items() %}
        {
          name  = "{{ name }}"
          value = "{{ value }}"
        }{% if not loop.last %},{% endif %}
{% endfor %}
      ]

      logConfiguration = {
        logDriver = "awslogs"
        options = {
          awslogs-group         = aws_cloudwatch_log_group.main.name
          awslogs-region        = "{{ region }}"
          awslogs-stream-prefix = "{{ normalized_service_name }}"
        }
      }
    }
  ])
}

resource "aws_ecs_service" "main" {
  name            = "{{ normalized_service_name }}"
  cluster         = "{{ cluster_arn }}"
  task_definition = aws_ecs_task_definition.main.arn
  desired_count   = {{ replicas }}
  launch_type     = "FARGATE"

  network_configuration {
    subnets = [
{% for subnet_id in private_subnet_ids %}
      "{{ subnet_id }}"{% if not loop.last %},{% endif %}
{% endfor %}
    ]
    security_groups  = ["{{ ecs_task_security_group_id }}"]
    assign_public_ip = false
  }

  load_balancer {
    target_group_arn = aws_lb_target_group.main.arn
    container_name   = "{{ normalized_service_name }}"
    container_port   = {{ port }}
  }
}

output "service_name" {
  value = aws_ecs_service.main.name
}

output "target_group_arn" {
  value = aws_lb_target_group.main.arn
}

output "log_group_name" {
  value = aws_cloudwatch_log_group.main.name
}
